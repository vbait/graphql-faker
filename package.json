{
  "name": "@vbait/graphql-faker",
  "version": "2.0.0",
  "description": "Mock or extend your GraphQL API with faked data. No coding required",
  "author": "Vitalii Baitaliuk <flampschelsea@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/vbait/graphql-faker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbait/graphql-faker.git"
  },
  "bugs": {
    "url": "https://github.com/vbait/graphql-faker/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "vb-graphql-faker": "dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "preversion": "npm ci --ignore-scripts && npm test",
    "test": "npm run lint && npm run check && npm run prettier:check && npm run check:spelling",
    "lint": "eslint --cache --max-warnings 0 .",
    "check": "tsc --noEmit",
    "start": "tsx watch src/index.ts",
    "debug": "tsx --inspect src/index.ts",
    "copy:graphql": "cp src/*.graphql dist/",
    "build": "rm -rf dist && tsc && npm run copy:graphql && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "example": "npm run build && node dist/index.js examples/test.faker.graphql",
    "prettier": "prettier --cache --ignore-path .gitignore --write --list-different .",
    "prettier:check": "prettier --cache --ignore-path .gitignore --check .",
    "check:spelling": "cspell --cache --no-progress '**/*'"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^17.0.2",
    "graphql-http": "^1.22.4",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "cspell": "^10.0.1",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
